# Ollama Environment Configuration
# This file configures Ollama to listen on all network interfaces
# allowing access from other hosts on the same network (192.168.*.*)

# Make Ollama accessible on all network interfaces
OLLAMA_HOST=0.0.0.0:11434

# Optional: Set the number of parallel requests (default: 1)
OLLAMA_NUM_PARALLEL=4

# Optional: Set maximum loaded models (default: 1)
# OLLAMA_MAX_LOADED_MODELS=2

# Optional: Set GPU memory limit (e.g., 4GB)
# OLLAMA_GPU_MEMORY_LIMIT=4GB

# Optional: Enable debug logging
OLLAMA_DEBUG=1
